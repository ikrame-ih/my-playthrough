DB_USER=postgres
DB_HOST=localhost
DB_NAME=myplaythrough
DB_PASSWORD=contraseña_aqui
# 5432 = Postgres instalado en el PC. 5433 = solo si conectas al contenedor Docker desde el host.
DB_PORT=5432
PORT=3000

# Secreto para firmar los JWT. Cámbialo por una cadena aleatoria larga y segura.
JWT_SECRET=cambia_esto_por_algo_secreto_y_largo

# Origen(es) del frontend. Varias URLs separadas por coma (cliente Vercel + presentación, etc.).
CORS_ORIGIN=http://localhost:5173

# Opcional: en proveedores cloud suele bastar con esto (reemplaza DB_*). Ej. Neon, Render Postgres.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Clave de la API de RAWG — RECOMENDADA (gratuita, 20.000 peticiones/mes).
# Sin esta clave el buscador solo devuelve juegos de Steam; títulos de Nintendo,
# PlayStation exclusivos u otras plataformas NO aparecerán en los resultados.
#
# Cómo obtenerla (menos de 2 minutos):
#   1. Ir a https://rawg.io/apidocs
#   2. Pulsar "Get API key" y crear una cuenta gratuita
#   3. Copiar la clave que aparece en el dashboard y pegarla abajo
#
RAWG_API_KEY=